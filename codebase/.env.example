# The SQLite database file path. In Docker, it's mapped to a volume.
DATABASE_URL="file:/app/data/dev.db"

# Public App Name
NEXT_PUBLIC_APP_NAME="TransitOps"

# Environment (development, test, production)
APP_ENV="development"

# Secret used for sessions/cookies (replace for production)
SESSION_SECRET="replace-with-local-dev-secret"

# Local email viewer (Mailpit in Docker)
SMTP_HOST="mailpit"
SMTP_PORT="1025"
